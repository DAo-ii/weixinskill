.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 20rpx;
}
.chat-area {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 20rpx;
}
.message {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  max-width: 80%;
}
.message.user {
  background-color: #07c160;
  color: white;
  margin-left: auto;
  text-align: right;
}
.message.assistant {
  background-color: white;
  color: #333;
}
.input-area {
  display: flex;
  padding: 20rpx 0;
  border-top: 1rpx solid #ddd;
}
.input {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
}
.send-btn {
  margin-left: 20rpx;
  background-color: #07c160;
  color: white;
  border-radius: 10rpx;
}
