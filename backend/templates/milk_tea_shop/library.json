## 🚀 快速使用

### 1. 引入接口

```javascript
const { queryProductList, createOrder } = require('./functions');

// 查询产品列表
const products = await queryProductList({ category: '奶茶' });

// 创建订单
const order = await createOrder({
    items: [{ id: 1, quantity: 2 }],
    customer: { name: '张三', phone: '13800138000' }
});
```

### 2. 引入组件

```javascript
const { ProductCard, CategoryTabs } = require('./components');

// 在页面中使用
Page({
    components: {
        ProductCard,
        CategoryTabs
    }
});
```

