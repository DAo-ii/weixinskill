/* 产品卡片样式 */
.product-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.product-info {
  flex: 1;
  margin-right: 20rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.price-value {
  font-size: 36rpx;
  color: #ff6b6b;
  font-weight: 700;
}

.product-action .btn-add {
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  padding: 0 24rpx;
}
